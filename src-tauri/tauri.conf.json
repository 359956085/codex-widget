{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Codex 额度小组件",
  "version": "0.1.0",
  "identifier": "cn.fengshi.codex-quota-widget",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:frontend",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Codex 额度小组件",
        "width": 390,
        "height": 236,
        "minWidth": 390,
        "minHeight": 236,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
